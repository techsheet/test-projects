# Editor configuration, see https://editorconfig.org
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.ts]
quote_type = single
ij_typescript_use_double_quotes = false
ij_typescript_keep_simple_blocks_in_one_line = true
ij_typescript_keep_simple_methods_in_one_line = true
ij_typescript_spaces_within_imports = true

[*.md]
max_line_length = 120
trim_trailing_whitespace = false

[*.{kt,kts}]
ktlint_code_style = ktlint_official
ktlint_standard_no-blank-line-between-parameters = disabled
ktlint_no-blank-line-in-list = disabled
ktlint_function_signature_style = multiline
ktlint_standard_import_order = true
indent_size = 2
continuation_indent_size = 2
indent_style = space
max_line_length = 140
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf
charset = utf-8
ktlint_chain_wrapping = wrap_always
ktlint_argument_list_wrapping = multiline
ktlint_class_signature_style = multiline
ktlint_function_signature_style = multiline
ktlint_colon_spacing = no_space_before,space_after
ktlint_package_name = lowercase
ktlint_field_name = camelCase
ktlint_blank_line_before_package = disabled

# Exclude mx line for test files
[ddiaas-hub/src/test/**/*.kt]
max_line_length = 160
#This file has 275 line length string for a message
[ddiaas-hub/src/main/kotlin/com/swisscom/ddiaas/hub/dns/model/record/RecordType.kt]
max_line_length = 300
#This file has very long regular expression for ipv6 address
[ddiaas-hub/src/main/kotlin/com/swisscom/ddiaas/hub/ipam/model/IpV6Address.kt]
max_line_length = 650


[*.mustache]
insert_final_newline = false